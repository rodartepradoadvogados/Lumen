DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# WhatsApp — Cloud API oficial da Meta. App Meta/webhook/verify token são únicos pra toda a
# plataforma (deixe em branco para manter a integração dormente); phoneNumberId/accessToken são
# por escritório e ficam na tabela WhatsappConfig (cadastrados em Configurações, não aqui).
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
