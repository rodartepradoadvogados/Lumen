# =============================================================================
# robo-publicacoes — variaveis de ambiente
# Copie este arquivo para ".env" e preencha os valores para rodar localmente.
# No Railway, configure as mesmas chaves em Project > Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados
# -----------------------------------------------------------------------------
# String de conexao Postgres (Railway injeta automaticamente ao adicionar o
# plugin Postgres, geralmente como DATABASE_URL). Se nao definida, o robo usa
# um arquivo SQLite local "./robo.db" (util para rodar/testar na sua maquina).
# Exemplo Postgres: postgresql://usuario:senha@host:5432/nome_do_banco
DATABASE_URL=

# -----------------------------------------------------------------------------
# OABs monitoradas
# -----------------------------------------------------------------------------
# Lista em JSON com uma entrada por advogado(a). Campos: nome, numero, uf.
# Defaults do escritorio Rodarte Prado Advogados (Goiania/GO):
#   Jairo Alexandre Rodarte e Silva - OAB/GO 78295
#   Rodrigo Araujo do Prado - OAB/GO 32943
# Se OABS_JSON nao for definida, o codigo usa esses dois valores como default
# (ver src/config.py). Para customizar, defina OABS_JSON exatamente assim:
OABS_JSON=[{"nome": "Jairo Alexandre Rodarte e Silva", "numero": "78295", "uf": "GO"}, {"nome": "Rodrigo Araujo do Prado", "numero": "32943", "uf": "GO"}]

# -----------------------------------------------------------------------------
# Janela de captura e intervalos
# -----------------------------------------------------------------------------
# Quantos dias para tras buscar publicacoes no DJEN a cada execucao
# (mantenha uma folga de alguns dias para cobrir eventuais atrasos/reprocessos
# da propria API do CNJ; a deduplicacao evita duplicar o que ja foi capturado).
JANELA_DIAS=5

# Intervalo, em horas, usado somente pelo modo "python -m src.main --loop"
# (agendamento interno via APScheduler). Quando o robo roda via Cron Job do
# Railway, este valor e ignorado (quem controla a frequencia e a expressao
# cron configurada no proprio Railway).
INTERVALO_HORAS=2

# -----------------------------------------------------------------------------
# E-mail (SMTP) - usado para notificar novidades
# -----------------------------------------------------------------------------
# Host e porta do provedor SMTP (exemplo Gmail: smtp.gmail.com / 465 com SSL).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
# Usuario e senha do SMTP. Para Gmail, use uma "senha de app" (nao a senha
# normal da conta) - https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASSWORD=

# Endereco(s) que devem receber as notificacoes. Aceita multiplos e-mails
# separados por virgula.
EMAIL_TO=rodartepradoadvogados@gmail.com

# -----------------------------------------------------------------------------
# Datajud (andamentos processuais)
# -----------------------------------------------------------------------------
# Chave publica de API do Datajud/CNJ. Solicite/consulte em:
# https://datajud-wiki.cnj.jus.br/api-publica/acesso
DATAJUD_API_KEY=

# -----------------------------------------------------------------------------
# Gemini (opcional) - resumo de textos longos de publicacoes/andamentos
# -----------------------------------------------------------------------------
# Se deixado em branco, o robo simplesmente nao gera resumo (nunca quebra o
# fluxo por causa disso). Obtenha uma chave gratuita em https://aistudio.google.com/
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
