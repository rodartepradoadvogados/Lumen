// Rodarte Prado Advogados - Sistema interno
// Schema completo: casos/atendimentos, agenda/kanban integrados, financeiro, contatos, publicações

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ EQUIPE ============

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  username     String?  @unique
  passwordHash String?
  role         String   @default("Advogado") // Advogado, Estagiário, Financeiro, Admin
  oab          String?
  phone        String?
  color        String   @default("#0f1f3d") // cor de identificação em cards/agenda
  isAdmin      Boolean  @default(false) // apenas Jairo/Rodrigo (sócios): aprovam exclusões, gerenciam equipe e acesso ao financeiro
  financeAccess Boolean @default(false) // controla visibilidade do módulo Financeiro; sócios sempre têm acesso independente deste campo
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  tasksResponsible   Task[]        @relation("TaskResponsible")
  casesResponsible   Case[]        @relation("CaseResponsible")
  comments           Comment[]
  mentions           Mention[]
  attendances        Attendance[]  @relation("AttendanceResponsible")
  attachments        Attachment[]
  documentTemplates  DocumentTemplate[]
  deletionRequested  DeletionRequest[] @relation("DeletionRequestedBy")
  deletionResolved   DeletionRequest[] @relation("DeletionResolvedBy")
  loginSessions      LoginSession[]
  notices            Notice[]
  publicationsAssigned Publication[] @relation("PublicationAssignee")
  googleCredentials    GoogleCredential[]
}

// ============ MURAL DE RECADOS ============

model Notice {
  id        String   @id @default(cuid())
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}

// ============ TIMESHEET (sessões de login) ============

model LoginSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  loginAt    DateTime @default(now())
  lastPingAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, loginAt])
}

// ============ CONTATOS ============

model Client {
  id            String   @id @default(cuid())
  name          String
  type          String   @default("PF") // PF | PJ
  document      String?
  rg            String?
  nationality   String?
  maritalStatus String?
  profession    String?
  email         String?
  phone         String?
  address       String?
  notes         String?
  createdAt     DateTime @default(now())

  cases       Case[]
  receivables Receivable[]
  publications Publication[]
}

model Lawyer {
  id        String   @id @default(cuid())
  name      String
  oab       String?
  firm      String?
  side      String   @default("PARCEIRO") // PARCEIRO | ADVERSO
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  document  String?
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())

  payables  Payable[]
}

// ============ CASOS / CARDS ============

model Case {
  id                String    @id @default(cuid())
  title             String
  type              String    @default("JUDICIAL") // JUDICIAL | EXTRAJUDICIAL | ATENDIMENTO | CONSULTIVO
  area              String?
  secondaryArea     String?
  status            String    @default("ATIVO") // ATIVO | SUSPENSO | ENCERRADO | ARQUIVADO
  folder            String?
  processNumber     String?
  court             String?
  forum             String?
  caseValue         Float?
  convictionValue   Float?
  instance          String?   // Instância Original
  currentInstance   String?   // Instância Atual
  distributedAt     DateTime?
  closedAt          DateTime?
  description       String?
  clientRole        String?   // papel do NOSSO cliente: Autor, Réu, Interessado, Recorrente, Recorrido...
  actionType        String?   // Ação (ex: Execução Fiscal)
  decision          String?
  outcome           String?
  tags              String?
  sourceUrl         String?
  lastHistoryAt     DateTime?
  lastHistoryDesc   String?

  opposingPartyName String?   // nome da parte adversa (sem cadastro próprio, só texto)
  opposingPartyRole String?   // AUTOR | REU | OUTRO — polo da parte adversa

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  clientId          String?
  client            Client?   @relation(fields: [clientId], references: [id])

  responsibleId     String?
  responsible       User?     @relation("CaseResponsible", fields: [responsibleId], references: [id])

  tasks             Task[]
  comments          Comment[]
  receivables       Receivable[]
  payables          Payable[]
  publications      Publication[]
  attachments       Attachment[]
  convertedFromAttendances Attendance[] @relation("AttendanceConvertedCase")
}

// ============ AGENDA + KANBAN (fonte única: Task) ============

model KanbanColumn {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  color     String   @default("#94a3b8")
  isDoneCol Boolean  @default(false)

  tasks     Task[]
}

model Task {
  id             String    @id @default(cuid())
  title          String
  type           String    @default("TAREFA") // TAREFA | EVENTO | AUDIENCIA | PERICIA | PRAZO
  description    String?
  dueDate        DateTime
  dueTime        String?
  priority       String    @default("MEDIA") // BAIXA | MEDIA | ALTA | URGENTE
  status         String    @default("PENDENTE") // PENDENTE | EM_ANDAMENTO | CONCLUIDO | CANCELADO
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Reunião (quando type = EVENTO)
  meetingType    String?   // PRESENCIAL | ONLINE
  location       String?
  meetingUrl     String?

  caseId         String?
  case           Case?     @relation(fields: [caseId], references: [id])

  attendanceId   String?
  attendance     Attendance? @relation(fields: [attendanceId], references: [id])

  publicationId  String?
  publication    Publication? @relation(fields: [publicationId], references: [id])

  responsibleId  String?
  responsible    User?     @relation("TaskResponsible", fields: [responsibleId], references: [id])

  columnId       String?
  column         KanbanColumn? @relation(fields: [columnId], references: [id])
  columnOrder    Int       @default(0)

  points         Int       @default(0) // TaskScore: pontuação de produtividade da tarefa

  comments       Comment[]
}

// ============ TASKSCORE (pontuação de produtividade por tipo de tarefa) ============

model TaskTypePoints {
  id     String @id @default(cuid())
  type   String @unique // TAREFA | EVENTO | AUDIENCIA | PERICIA | PRAZO
  points Int    @default(10)
}

// ============ WORKFLOWS (cadeias padronizadas de tarefas) ============

model WorkflowTemplate {
  id          String   @id @default(cuid())
  name        String
  area        String?
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  steps       WorkflowStep[]
}

model WorkflowStep {
  id         String   @id @default(cuid())
  order      Int      @default(0)
  title      String
  taskType   String   @default("TAREFA") // TAREFA | EVENTO | AUDIENCIA | PERICIA | PRAZO
  offsetDays Int      @default(0) // dias após a aplicação do workflow
  priority   String   @default("MEDIA") // BAIXA | MEDIA | ALTA | URGENTE
  role       String?  // cargo sugerido do responsável (Advogado, Estagiário, etc.)
  points     Int?     // pontuação opcional; se nula usa o padrão do tipo

  templateId String
  template   WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  createdAt DateTime  @default(now())

  authorId  String
  author    User      @relation(fields: [authorId], references: [id])

  taskId    String?
  task      Task?     @relation(fields: [taskId], references: [id])

  caseId    String?
  case      Case?     @relation(fields: [caseId], references: [id])

  mentions  Mention[]
}

model Mention {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============ ATENDIMENTO (setor de atendimento / triagem) ============

model Attendance {
  id            String   @id @default(cuid())
  clientName    String
  contact       String?
  subject       String
  area          String?  // matéria
  description   String?  // descrição detalhada do que precisa
  channel       String   @default("WHATSAPP") // WHATSAPP | EMAIL | TELEFONE | PRESENCIAL
  status        String   @default("NOVO") // NOVO | EM_TRIAGEM | CONVERTIDO | ARQUIVADO
  notes         String?
  createdAt     DateTime @default(now())

  // Funil comercial (CRM de captação) — eixo independente do status operacional acima
  stage          String    @default("NOVO") // NOVO | QUALIFICACAO | PROPOSTA | FECHADO | PERDIDO
  estimatedValue Float?    // valor estimado do contrato
  leadSource     String?   // INDICACAO | INSTAGRAM | GOOGLE | SITE | WHATSAPP | OUTRO
  lostReason     String?   // preenchido ao mover para PERDIDO
  nextContactAt  DateTime? // data do próximo contato/follow-up
  stageChangedAt DateTime? // quando o estágio comercial mudou pela última vez

  // Integração WhatsApp (Cloud API oficial da Meta)
  waPhone         String?   // telefone do cliente no WhatsApp (E.164), usado como chave de conversa
  waLastMessageAt DateTime? // instante da última mensagem trocada nesta conversa

  responsibleId String?
  responsible   User?    @relation("AttendanceResponsible", fields: [responsibleId], references: [id])

  convertedCaseId String?
  convertedCase   Case?  @relation("AttendanceConvertedCase", fields: [convertedCaseId], references: [id])

  tasks            Task[]
  attachments      Attachment[]
  whatsappMessages WhatsappMessage[]

  @@index([waPhone])
}

// ============ WHATSAPP (mensagens da integração com a Cloud API da Meta) ============

model WhatsappMessage {
  id           String     @id @default(cuid())
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  direction    String     // "IN" (do cliente) | "OUT" (do escritório)
  body         String
  waMessageId  String?    @unique // id da mensagem na Meta (dedupe)
  status       String     @default("RECEIVED") // RECEIVED | SENT | FAILED
  fromNumber   String?    // telefone do cliente (E.164)
  createdAt    DateTime   @default(now())

  @@index([attendanceId, createdAt])
}

// ============ ANEXOS (referência ao Google Drive) ============

model Attachment {
  id           String   @id @default(cuid())
  name         String
  driveUrl     String
  createdAt    DateTime @default(now())

  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  caseId       String?
  case         Case?    @relation(fields: [caseId], references: [id])

  attendanceId String?
  attendance   Attendance? @relation(fields: [attendanceId], references: [id])
}

// ============ MODELOS DE DOCUMENTO (contratos, procurações, declarações...) ============

model DocumentTemplate {
  id           String   @id @default(cuid())
  name         String   // ex: "Contrato de honorários com pagamento de entrada + êxito"
  category     String   // CONTRATO | PETICAO | PROCURACAO | DECLARACAO_HIPOSSUFICIENCIA | DECLARACAO_MORADIA | OUTRO
  driveUrl     String
  createdAt    DateTime @default(now())

  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
}

// ============ SOLICITAÇÕES DE EXCLUSÃO (aprovação de admin) ============

model DeletionRequest {
  id             String    @id @default(cuid())
  entityType     String    // TASK | CASE | ATTENDANCE
  entityId       String
  entityLabel    String    // snapshot legível (título/nome) para exibir mesmo após excluir
  status         String    @default("PENDENTE") // PENDENTE | APROVADA | REJEITADA
  createdAt      DateTime  @default(now())

  requestedById  String
  requestedBy    User      @relation("DeletionRequestedBy", fields: [requestedById], references: [id])

  resolvedById   String?
  resolvedBy     User?     @relation("DeletionResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt     DateTime?
}

// ============ INTEGRAÇÃO GOOGLE DRIVE ============

model GoogleCredential {
  id                String   @id @default(cuid())
  accountEmail      String   @unique
  refreshToken      String
  isPrimaryDrive    Boolean  @default(false) // conta usada para anexos/documentos (uma só, escolhida na primeira conexão)
  syncJusbrasil     Boolean  @default(true)  // se a caixa desta conta é varrida em busca de e-mails do Jusbrasil
  folderId          String?
  templatesFolderId String?
  generatedFolderId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userId            String?
  user              User?    @relation(fields: [userId], references: [id])
}

// ============ FINANCEIRO ============

model FinancialCategory {
  id        String   @id @default(cuid())
  code      String   // ex: "1.1", "2.1.1.1" - ordena e mostra a hierarquia (plano de contas)
  name      String
  kind      String   // RECEITA | DESPESA
  order     Int      @default(0)
  createdAt DateTime @default(now())

  parentId  String?
  parent    FinancialCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  FinancialCategory[] @relation("CategoryTree")

  payables    Payable[]
  receivables Receivable[]
}

model CostCenter {
  id        String   @id @default(cuid())
  name      String
  notes     String?
  createdAt DateTime @default(now())

  payables    Payable[]
  receivables Receivable[]
}

model Payable {
  id               String    @id @default(cuid())
  description      String
  supplier         String?
  amount           Float
  dueDate          DateTime
  paidDate         DateTime?
  paidAmount       Float?
  status           String    @default("PENDENTE") // PENDENTE | PAGO | ATRASADO | CANCELADO
  notes            String?
  noDueDate        Boolean   @default(false) // parcela sem vencimento definido — aparece na Central de Alertas
  groupId          String?   // agrupa parcelas geradas juntas
  installmentNumber Int?
  installmentTotal  Int?
  paymentReceiptNumber String? // nº do comprovante de pagamento; pode ser o mesmo em várias contas quitadas na mesma transferência
  paymentMethod    String?   // DEBITO | CREDITO | PIX | TRANSFERENCIA | BOLETO | OUTROS
  createdAt        DateTime  @default(now())

  categoryId   String?
  category     FinancialCategory? @relation(fields: [categoryId], references: [id])

  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  caseId       String?
  case         Case?     @relation(fields: [caseId], references: [id])

  supplierId   String?
  supplierRef  Supplier? @relation(fields: [supplierId], references: [id])
}

model Receivable {
  id               String    @id @default(cuid())
  description      String
  amount           Float
  dueDate          DateTime
  paidDate         DateTime?
  paidAmount       Float?
  status           String    @default("PENDENTE") // PENDENTE | PAGO | ATRASADO | CANCELADO
  kind             String    @default("HONORARIOS_CONTRATUAIS") // HONORARIOS_CONTRATUAIS | HONORARIOS_SUCUMBENCIAIS | REEMBOLSO | OUTROS
  notes            String?
  noDueDate        Boolean   @default(false)
  groupId          String?
  installmentNumber Int?
  installmentTotal  Int?
  isSuccessPortion Boolean   @default(false) // parcela "a receber no êxito"
  paymentReceiptNumber String? // nº do comprovante de pagamento; pode ser o mesmo em várias contas quitadas na mesma transferência
  paymentMethod    String?   // DEBITO | CREDITO | PIX | TRANSFERENCIA | BOLETO | OUTROS
  createdAt        DateTime  @default(now())

  categoryId   String?
  category     FinancialCategory? @relation(fields: [categoryId], references: [id])

  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  clientId     String?
  client       Client?   @relation(fields: [clientId], references: [id])

  caseId       String?
  case         Case?     @relation(fields: [caseId], references: [id])
}

// ============ PUBLICAÇÕES / ANDAMENTOS ============

model Publication {
  id                String    @id @default(cuid())
  kind              String    @default("PUBLICACAO") // PUBLICACAO | ANDAMENTO
  source            String    @default("DJE") // DJE | PJE | ESAJ | PROJUDI | MANUAL | JUSBRASIL_EMAIL
  content           String
  publishedAt       DateTime
  read              Boolean   @default(false)
  deadlineGenerated Boolean   @default(false)
  lawyerTag         String?   // Jairo | Rodrigo | Jairo e Rodrigo — identificado pela OAB citada no conteúdo
  createdAt         DateTime  @default(now())

  emailMessageId    String?   @unique
  emailAccount      String?
  emailSubject      String?
  processNumberRaw  String?

  caseId            String?
  case              Case?     @relation(fields: [caseId], references: [id])

  clientId          String?   // preenchido quando não há processo compatível mas o nome de um cliente cadastrado aparece no conteúdo
  client            Client?   @relation(fields: [clientId], references: [id])

  // RIDT — fila de triagem com atribuição de responsável
  assignedToId      String?
  assignedTo        User?     @relation("PublicationAssignee", fields: [assignedToId], references: [id])
  triageStatus      String    @default("PENDENTE") // PENDENTE | EM_ANALISE | TRATADA

  tasks             Task[]
}

// ============ TABELAS DO ROBÔ PYTHON (robo-publicacoes/, Railway) ============
//
// Estes 4 modelos NÃO são usados pelo código TypeScript — eles existem só para
// que o Prisma "enxergue" as tabelas que o robô Python (SQLAlchemy) cria no
// MESMO banco Postgres. Sem isso, `prisma db push` trata essas tabelas como
// "órfãs" (não descritas no schema) e as APAGA na próxima migração — foi
// exatamente isso que aconteceu em 2026-07-20. Os tipos/nomes de coluna abaixo
// espelham robo-publicacoes/src/db.py; se o robô mudar a estrutura lá, replicar
// a mudança aqui também.

model RoboPublicacao {
  idComunicacao        String    @id @map("id_comunicacao")
  oab                  String
  uf                   String
  nomeAdvogado         String?   @map("nome_advogado")
  numeroProcesso       String    @map("numero_processo")
  tribunal             String?
  dataDisponibilizacao String?   @map("data_disponibilizacao")
  tipoComunicacao      String?   @map("tipo_comunicacao")
  teor                 String?
  dataCaptura          DateTime  @default(now()) @map("data_captura")
  statusLido           Boolean   @default(false) @map("status_lido")

  @@map("publicacoes")
}

model RoboAndamento {
  id                 Int      @id @default(autoincrement())
  numeroProcesso     String   @map("numero_processo")
  tribunal           String?
  dataMovimentacao   String   @map("data_movimentacao")
  codigoMovimento    String   @map("codigo_movimento")
  descricaoMovimento String?  @map("descricao_movimento")
  dataCaptura        DateTime @default(now()) @map("data_captura")
  statusLido         Boolean  @default(false) @map("status_lido")

  @@unique([numeroProcesso, dataMovimentacao, codigoMovimento], name: "uq_andamento_processo_data_codigo")
  @@map("andamentos")
}

model RoboProcessoMonitorado {
  numeroProcesso String   @id @map("numero_processo")
  origem         String
  dataInclusao   DateTime @default(now()) @map("data_inclusao")
  oabRelacionada String?  @map("oab_relacionada")

  @@map("processos_monitorados")
}

model RoboExecucaoLog {
  id          Int      @id @default(autoincrement())
  fonte       String
  sucesso     Boolean
  detalhe     String?
  executadoEm DateTime @default(now()) @map("executado_em")

  @@map("execucao_log")
}
