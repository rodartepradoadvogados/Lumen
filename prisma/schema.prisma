// Rodarte Prado Advogados - Sistema interno
// Schema completo: casos/atendimentos, agenda/kanban integrados, financeiro, contatos, publicações

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ EQUIPE ============

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  username     String?  @unique
  passwordHash String?
  role         String   @default("Advogado") // Advogado, Estagiário, Financeiro, Admin
  oab          String?
  phone        String?
  color        String   @default("#0f1f3d") // cor de identificação em cards/agenda
  isAdmin      Boolean  @default(false) // apenas Jairo/Rodrigo (sócios): aprovam exclusões, gerenciam equipe e acesso ao financeiro
  financeAccess Boolean @default(false) // controla visibilidade do módulo Financeiro; sócios sempre têm acesso independente deste campo
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  resetTokenHash   String?   @unique // hash SHA-256 do token de redefinição de senha (nunca o token puro)
  resetTokenExpiry DateTime?

  // Preferências de notificação push (app mobile) — cada uma liga/desliga um tipo de aviso,
  // configurável pelo próprio usuário em Configurações. Ligadas por padrão (opt-out, não
  // opt-in) para quem já ativou notificações neste aparelho continuar recebendo tudo até
  // decidir desligar algo específico.
  notifyAndamentos       Boolean @default(true)
  notifyPublicacoes      Boolean @default(true)
  notifyTarefasDelegadas Boolean @default(true)
  notifyAgendaDia        Boolean @default(true)

  pushSubscriptions  PushSubscription[]
  tasksResponsible   Task[]        @relation("TaskResponsible")
  tasksDelegated     Task[]        @relation("TaskDelegatedBy")
  casesResponsible   Case[]        @relation("CaseResponsible")
  comments           Comment[]
  mentions           Mention[]
  attendances        Attendance[]  @relation("AttendanceResponsible")
  attachments        Attachment[]
  documentTemplates  DocumentTemplate[]
  deletionRequested  DeletionRequest[] @relation("DeletionRequestedBy")
  deletionResolved   DeletionRequest[] @relation("DeletionResolvedBy")
  loginSessions      LoginSession[]
  notices            Notice[]
  publicationsAssigned Publication[] @relation("PublicationAssignee")
  googleCredentials    GoogleCredential[]
  blogPostsReviewed    BlogPost[]    @relation("BlogPostReviewer")
  emailsSent           EmailMessage[] @relation("EmailMessageSentBy")
  assessoriasResponsible      Assessoria[]          @relation("AssessoriaResponsible")
  assessoriaDocumentsUploaded AssessoriaDocumento[] @relation("AssessoriaDocumentoUploadedBy")
}

// Uma inscrição de push por aparelho/navegador em que o usuário ativou notificações
// (ver components/mobile/NotificationPreferences.tsx) — um mesmo usuário pode ter mais de
// uma (celular + tablet, por exemplo). endpoint é o identificador único que o navegador
// gera; p256dh/auth são as chaves de criptografia exigidas pelo protocolo Web Push.
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============ MURAL DE RECADOS ============

model Notice {
  id        String   @id @default(cuid())
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}

// ============ TIMESHEET (sessões de login) ============

model LoginSession {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  loginAt    DateTime @default(now())
  lastPingAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId, loginAt])
}

// ============ CONTATOS ============

model Client {
  id            String   @id @default(cuid())
  name          String
  type          String   @default("PF") // PF | PJ
  document      String?
  rg            String?
  nationality   String?
  maritalStatus String?
  profession    String?
  email         String?
  phone         String?
  address       String?
  notes         String?
  createdAt     DateTime @default(now())

  cases       Case[]
  receivables Receivable[]
  publications Publication[]
  attendances Attendance[] @relation("AttendanceClient")
  assessoria  Assessoria?
}

model Lawyer {
  id        String   @id @default(cuid())
  name      String
  oab       String?
  firm      String?
  side      String   @default("PARCEIRO") // PARCEIRO | ADVERSO
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  document  String?
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())

  payables  Payable[]
}

// ============ CASOS / CARDS ============

model Case {
  id                String    @id @default(cuid())
  title             String
  type              String    @default("JUDICIAL") // JUDICIAL | EXTRAJUDICIAL | ATENDIMENTO | CONSULTIVO
  area              String?
  secondaryArea     String?
  status            String    @default("ATIVO") // ATIVO | SUSPENSO | ENCERRADO | ARQUIVADO
  folder            String?
  processNumber     String?
  court             String?
  forum             String?
  tribunal          String?   // Sigla do tribunal (ex: TJGO, TRF1, TST)
  caseValue         Float?
  convictionValue   Float?
  instance          String?   // Instância Original
  currentInstance   String?   // Instância Atual
  distributedAt     DateTime?
  closedAt          DateTime?
  description       String?
  clientRole        String?   // papel do NOSSO cliente: Autor, Réu, Interessado, Recorrente, Recorrido...
  actionType        String?   // Ação (ex: Execução Fiscal)
  decision          String?
  outcome           String?
  tags              String?
  sourceUrl         String?
  lastHistoryAt     DateTime?
  lastHistoryDesc   String?

  opposingPartyName     String?   // nome da parte adversa (cadastro simplificado, só texto)
  opposingPartyRole     String?   // AUTOR | REU | OUTRO — polo da parte adversa
  opposingPartyDocument String?   // CPF/CNPJ da parte adversa (opcional)
  opposingPartyAddress  String?   // endereço da parte adversa (opcional)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  clientId          String?
  client            Client?   @relation(fields: [clientId], references: [id])

  responsibleId     String?
  responsible       User?     @relation("CaseResponsible", fields: [responsibleId], references: [id])

  // Vínculo explícito com uma Assessoria (opcional) — escolhido no cadastro do processo,
  // para importar este caso diretamente para dentro do acompanhamento daquela assessoria.
  // Independente do clientId: o mesmo cliente pode ter processos que não fazem parte do
  // contrato de assessoria continuada.
  assessoriaId      String?
  assessoria        Assessoria? @relation(fields: [assessoriaId], references: [id])

  tasks             Task[]
  comments          Comment[]
  receivables       Receivable[]
  payables          Payable[]
  publications      Publication[]
  attachments       Attachment[]
  convertedFromAttendances Attendance[] @relation("AttendanceConvertedCase")
  assessoriaDocumentos AssessoriaDocumento[]
}

// ============ AGENDA + KANBAN (fonte única: Task) ============

model KanbanColumn {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  color     String   @default("#94a3b8")
  isDoneCol Boolean  @default(false)

  tasks     Task[]
}

model Task {
  id             String    @id @default(cuid())
  title          String
  type           String    @default("TAREFA") // TAREFA | EVENTO | AUDIENCIA | PERICIA | PRAZO
  description    String?
  dueDate        DateTime
  dueTime        String?
  // Prazo de segurança: calculado automaticamente como 24h antes do dueDate ("prazo fatal") —
  // hoje só preenchido por delegateTask (lib/actions/tasks.ts). Aparece na Agenda como um
  // segundo evento, em cor distinta, no dia anterior ao prazo fatal.
  safetyDueDate  DateTime?
  priority       String    @default("MEDIA") // BAIXA | MEDIA | ALTA | URGENTE
  status         String    @default("PENDENTE") // PENDENTE | EM_ANDAMENTO | CONCLUIDO | CANCELADO
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Reunião (quando type = EVENTO)
  meetingType    String?   // PRESENCIAL | ONLINE
  location       String?
  meetingUrl     String?

  caseId         String?
  case           Case?     @relation(fields: [caseId], references: [id])

  attendanceId   String?
  attendance     Attendance? @relation(fields: [attendanceId], references: [id])

  publicationId  String?
  publication    Publication? @relation(fields: [publicationId], references: [id])

  licitacaoId    String?
  licitacao      Licitacao? @relation(fields: [licitacaoId], references: [id])

  responsibleId  String?
  responsible    User?     @relation("TaskResponsible", fields: [responsibleId], references: [id])

  // Delegação: quando preenchido, indica que a tarefa foi atribuída por outra pessoa
  // (não criada pelo próprio responsável) — usado para gerar alerta/notificação só
  // para quem recebeu, até que ela seja aberta (delegationAcknowledgedAt).
  delegatedById  String?
  delegatedBy    User?     @relation("TaskDelegatedBy", fields: [delegatedById], references: [id])
  delegationAcknowledgedAt DateTime?

  columnId       String?
  column         KanbanColumn? @relation(fields: [columnId], references: [id])
  columnOrder    Int       @default(0)

  points         Int       @default(0) // TaskScore: pontuação de produtividade da tarefa

  comments       Comment[]
}

// ============ TASKSCORE (pontuação de produtividade por tipo de tarefa) ============

model TaskTypePoints {
  id     String @id @default(cuid())
  type   String @unique // TAREFA | EVENTO | AUDIENCIA | PERICIA | PRAZO
  points Int    @default(10)
}

// ============ WORKFLOWS (cadeias padronizadas de tarefas) ============

model WorkflowTemplate {
  id          String   @id @default(cuid())
  name        String
  area        String?
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  steps       WorkflowStep[]
}

model WorkflowStep {
  id         String   @id @default(cuid())
  order      Int      @default(0)
  title      String
  taskType   String   @default("TAREFA") // TAREFA | EVENTO | AUDIENCIA | PERICIA | PRAZO
  offsetDays Int      @default(0) // dias após a aplicação do workflow
  priority   String   @default("MEDIA") // BAIXA | MEDIA | ALTA | URGENTE
  role       String?  // cargo sugerido do responsável (Advogado, Estagiário, etc.)
  points     Int?     // pontuação opcional; se nula usa o padrão do tipo

  templateId String
  template   WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  createdAt DateTime  @default(now())

  authorId  String
  author    User      @relation(fields: [authorId], references: [id])

  taskId    String?
  task      Task?     @relation(fields: [taskId], references: [id])

  caseId    String?
  case      Case?     @relation(fields: [caseId], references: [id])

  mentions  Mention[]
}

model Mention {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============ ATENDIMENTO (setor de atendimento / triagem) ============

model Attendance {
  id            String   @id @default(cuid())
  clientName    String
  contact       String?  // legado: telefone/e-mail juntos em texto livre (formulários antigos, mantido sem migração destrutiva)
  contactPhone  String?  // telefone do contato, separado do e-mail (clientEmail abaixo)
  subject       String
  area          String?  // matéria
  description   String?  // descrição detalhada do que precisa
  channel       String   @default("WHATSAPP") // WHATSAPP | EMAIL | TELEFONE | PRESENCIAL
  status        String   @default("NOVO") // NOVO | EM_TRIAGEM | CONVERTIDO | ARQUIVADO | RASCUNHO
  notes         String?
  createdAt     DateTime @default(now())

  // Funil comercial (CRM de captação) — eixo independente do status operacional acima
  stage          String    @default("NOVO") // NOVO | QUALIFICACAO | PROPOSTA | FECHADO | PERDIDO
  estimatedValue Float?    // valor estimado do contrato
  leadSource     String?   // INDICACAO | INSTAGRAM | GOOGLE | SITE | WHATSAPP | OUTRO
  lostReason     String?   // preenchido ao mover para PERDIDO
  nextContactAt  DateTime? // data do próximo contato/follow-up
  stageChangedAt DateTime? // quando o estágio comercial mudou pela última vez

  // Integração WhatsApp (Cloud API oficial da Meta)
  waPhone         String?   // telefone do cliente no WhatsApp (E.164), usado como chave de conversa
  waLastMessageAt DateTime? // instante da última mensagem trocada nesta conversa

  // Integração E-mail (resposta via Gmail da conta Google do próprio advogado)
  // Reaproveitado também como e-mail do contato no formulário de criação do atendimento.
  clientEmail     String?   // e-mail do cliente para resposta; preenchido manualmente na tela

  // Vínculo com cadastro de Client — preenchido ao selecionar um cliente já cadastrado
  // na busca, ou automaticamente após "Cadastrar novo cliente" ser finalizado (não em rascunho).
  clientId String?
  client   Client? @relation("AttendanceClient", fields: [clientId], references: [id])

  responsibleId String?
  responsible   User?    @relation("AttendanceResponsible", fields: [responsibleId], references: [id])

  convertedCaseId String?
  convertedCase   Case?  @relation("AttendanceConvertedCase", fields: [convertedCaseId], references: [id])

  // Mesmo vínculo opcional com Assessoria disponível no cadastro de Processo (ver Case.assessoriaId).
  assessoriaId String?
  assessoria   Assessoria? @relation(fields: [assessoriaId], references: [id])

  tasks            Task[]
  attachments      Attachment[]
  whatsappMessages WhatsappMessage[]
  emailMessages    EmailMessage[]

  @@index([waPhone])
}

// ============ WHATSAPP (mensagens da integração com a Cloud API da Meta) ============

model WhatsappMessage {
  id           String     @id @default(cuid())
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  direction    String     // "IN" (do cliente) | "OUT" (do escritório)
  body         String
  waMessageId  String?    @unique // id da mensagem na Meta (dedupe)
  status       String     @default("RECEIVED") // RECEIVED | SENT | FAILED
  fromNumber   String?    // telefone do cliente (E.164)
  createdAt    DateTime   @default(now())

  @@index([attendanceId, createdAt])
}

// ============ E-MAIL (resposta ao cliente via Gmail da conta Google do próprio advogado) ============

model EmailMessage {
  id            String     @id @default(cuid())
  attendanceId  String
  attendance    Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  direction     String     // "OUT" (por enquanto só enviamos, não há ingestão de e-mail recebido nesse fluxo)
  toAddress     String
  fromAddress   String
  subject       String
  body          String
  sentByUserId  String?
  sentByUser    User?      @relation("EmailMessageSentBy", fields: [sentByUserId], references: [id])
  status        String     @default("SENT") // SENT | FAILED
  errorMessage  String?
  createdAt     DateTime   @default(now())

  @@index([attendanceId, createdAt])
}

// ============ ANEXOS (referência ao Google Drive) ============

model Attachment {
  id           String   @id @default(cuid())
  name         String
  driveUrl     String
  docType      String   @default("OUTRO") // ver lib/documentTypes.ts
  createdAt    DateTime @default(now())

  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  caseId       String?
  case         Case?    @relation(fields: [caseId], references: [id])

  attendanceId String?
  attendance   Attendance? @relation(fields: [attendanceId], references: [id])
}

// ============ MODELOS DE DOCUMENTO (contratos, procurações, declarações...) ============

model DocumentTemplate {
  id           String   @id @default(cuid())
  name         String   // ex: "Contrato de honorários com pagamento de entrada + êxito"
  category     String   // CONTRATO | PETICAO | PROCURACAO | DECLARACAO_HIPOSSUFICIENCIA | DECLARACAO_MORADIA | OUTRO
  driveUrl     String
  createdAt    DateTime @default(now())

  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
}

// ============ SOLICITAÇÕES DE EXCLUSÃO (aprovação de admin) ============

model DeletionRequest {
  id             String    @id @default(cuid())
  entityType     String    // TASK | CASE | ATTENDANCE
  entityId       String
  entityLabel    String    // snapshot legível (título/nome) para exibir mesmo após excluir
  status         String    @default("PENDENTE") // PENDENTE | APROVADA | REJEITADA
  createdAt      DateTime  @default(now())

  requestedById  String
  requestedBy    User      @relation("DeletionRequestedBy", fields: [requestedById], references: [id])

  resolvedById   String?
  resolvedBy     User?     @relation("DeletionResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt     DateTime?
}

// ============ INTEGRAÇÃO GOOGLE DRIVE ============

model GoogleCredential {
  id                String   @id @default(cuid())
  accountEmail      String   @unique
  refreshToken      String
  isPrimaryDrive    Boolean  @default(false) // conta usada para anexos/documentos (uma só, escolhida na primeira conexão)
  syncJusbrasil     Boolean  @default(true)  // se a caixa desta conta é varrida em busca de e-mails do Jusbrasil
  folderId          String?
  templatesFolderId String?
  generatedFolderId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userId            String?
  user              User?    @relation(fields: [userId], references: [id])
}

// ============ FINANCEIRO ============

model FinancialCategory {
  id        String   @id @default(cuid())
  code      String   // ex: "1.1", "2.1.1.1" - ordena e mostra a hierarquia (plano de contas)
  name      String
  kind      String   // RECEITA | DESPESA
  order     Int      @default(0)
  createdAt DateTime @default(now())

  parentId  String?
  parent    FinancialCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  FinancialCategory[] @relation("CategoryTree")

  payables    Payable[]
  receivables Receivable[]
}

model CostCenter {
  id        String   @id @default(cuid())
  name      String
  notes     String?
  createdAt DateTime @default(now())

  payables    Payable[]
  receivables Receivable[]
}

model Payable {
  id               String    @id @default(cuid())
  description      String
  supplier         String?
  amount           Float
  dueDate          DateTime
  paidDate         DateTime?
  paidAmount       Float?
  status           String    @default("PENDENTE") // PENDENTE | PAGO | ATRASADO | CANCELADO
  notes            String?
  noDueDate        Boolean   @default(false) // parcela sem vencimento definido — aparece na Central de Alertas
  groupId          String?   // agrupa parcelas geradas juntas
  installmentNumber Int?
  installmentTotal  Int?
  paymentReceiptNumber String? // nº do comprovante de pagamento; pode ser o mesmo em várias contas quitadas na mesma transferência
  paymentMethod    String?   // DEBITO | CREDITO | PIX | TRANSFERENCIA | BOLETO | OUTROS
  createdAt        DateTime  @default(now())

  categoryId   String?
  category     FinancialCategory? @relation(fields: [categoryId], references: [id])

  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  caseId       String?
  case         Case?     @relation(fields: [caseId], references: [id])

  supplierId   String?
  supplierRef  Supplier? @relation(fields: [supplierId], references: [id])
}

model Receivable {
  id               String    @id @default(cuid())
  description      String
  amount           Float
  dueDate          DateTime
  paidDate         DateTime?
  paidAmount       Float?
  status           String    @default("PENDENTE") // PENDENTE | PAGO | ATRASADO | CANCELADO
  kind             String    @default("HONORARIOS_CONTRATUAIS") // HONORARIOS_CONTRATUAIS | HONORARIOS_SUCUMBENCIAIS | REEMBOLSO | OUTROS
  notes            String?
  noDueDate        Boolean   @default(false)
  groupId          String?
  installmentNumber Int?
  installmentTotal  Int?
  isSuccessPortion Boolean   @default(false) // parcela "a receber no êxito"
  paymentReceiptNumber String? // nº do comprovante de pagamento; pode ser o mesmo em várias contas quitadas na mesma transferência
  paymentMethod    String?   // DEBITO | CREDITO | PIX | TRANSFERENCIA | BOLETO | OUTROS
  createdAt        DateTime  @default(now())

  categoryId   String?
  category     FinancialCategory? @relation(fields: [categoryId], references: [id])

  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  clientId     String?
  client       Client?   @relation(fields: [clientId], references: [id])

  caseId       String?
  case         Case?     @relation(fields: [caseId], references: [id])

  honorario    Honorario?
}

// ============ ASSESSORIA JURÍDICA ============
// Contêiner por empresa cliente (Client.type = "PJ") para tudo que é contínuo — documentos,
// honorário fixo mensal, licitações — sem se misturar com o controle de Processos individuais.
// Processos e Contas a Receber continuam existindo exatamente como hoje; a Assessoria só os
// referencia pelo cliente já cadastrado (nunca duplica dado).

model Assessoria {
  id            String    @id @default(cuid())
  status        String    @default("ATIVA") // ATIVA | SUSPENSA | ENCERRADA
  startDate     DateTime  @default(now())
  monthlyFee    Float
  dueDay        Int       @default(5) // dia do mês de vencimento do honorário
  planningNotes String?
  driveFolderId String?   // pasta raiz da empresa em "RP Financeiro - Assessoria/{empresa}"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clientId      String    @unique
  client        Client    @relation(fields: [clientId], references: [id])

  responsibleId String?
  responsible   User?     @relation("AssessoriaResponsible", fields: [responsibleId], references: [id])

  documents     AssessoriaDocumento[]
  honorarios    Honorario[]
  licitacoes    Licitacao[]
  cases         Case[]
  attendances   Attendance[]
}

model AssessoriaDocumento {
  id           String     @id @default(cuid())
  name         String
  docType      String     // CONTRATO | PARECER | ACAO_VINCULADA | LICITACAO | REGIMENTO_INTERNO | OUTRO
  driveUrl     String
  date         DateTime   @default(now())
  createdAt    DateTime   @default(now())

  assessoriaId String
  assessoria   Assessoria @relation(fields: [assessoriaId], references: [id])

  caseId       String?
  case         Case?      @relation(fields: [caseId], references: [id])

  uploadedById String?
  uploadedBy   User?      @relation("AssessoriaDocumentoUploadedBy", fields: [uploadedById], references: [id])
}

// Deliberadamente sem amount/dueDate/status/paidDate próprios — esses dados vivem só no
// Receivable vinculado (Contas a Receber já tem toda a lógica de status/pagamento). Duplicar
// esses campos aqui criaria duas fontes de verdade que poderiam divergir.
model Honorario {
  id           String     @id @default(cuid())
  competencia  String     // "2026-08"
  createdAt    DateTime   @default(now())

  assessoriaId String
  assessoria   Assessoria @relation(fields: [assessoriaId], references: [id])

  receivableId String     @unique
  receivable   Receivable @relation(fields: [receivableId], references: [id])

  @@unique([assessoriaId, competencia])
}

model Licitacao {
  id            String     @id @default(cuid())
  objeto        String
  orgao         String
  modalidade    String?
  dataAbertura  DateTime?
  prazoFinal    DateTime?
  valorEstimado Float?
  editalUrl     String?
  status        String     @default("EM_ANALISE") // EM_ANALISE | PARTICIPANDO | VENCEDORA | PERDIDA | CANCELADA
  createdAt     DateTime   @default(now())

  assessoriaId  String
  assessoria    Assessoria @relation(fields: [assessoriaId], references: [id])

  tasks         Task[]
}

// ============ PUBLICAÇÕES / ANDAMENTOS ============

model Publication {
  id                String    @id @default(cuid())
  kind              String    @default("PUBLICACAO") // PUBLICACAO | ANDAMENTO
  source            String    @default("DJE") // DJE | PJE | ESAJ | PROJUDI | MANUAL | JUSBRASIL_EMAIL
  content           String
  publishedAt       DateTime
  read              Boolean   @default(false)
  deadlineGenerated Boolean   @default(false)
  lawyerTag         String?   // Jairo | Rodrigo | Jairo e Rodrigo — identificado pela OAB citada no conteúdo
  createdAt         DateTime  @default(now())

  emailMessageId    String?   @unique
  emailAccount      String?
  emailSubject      String?
  processNumberRaw  String?

  caseId            String?
  case              Case?     @relation(fields: [caseId], references: [id])

  clientId          String?   // preenchido quando não há processo compatível mas o nome de um cliente cadastrado aparece no conteúdo
  client            Client?   @relation(fields: [clientId], references: [id])

  // RIDT — fila de triagem com atribuição de responsável
  assignedToId      String?
  assignedTo        User?     @relation("PublicationAssignee", fields: [assignedToId], references: [id])
  triageStatus      String    @default("PENDENTE") // PENDENTE | EM_ANALISE | TRATADA

  tasks             Task[]
}

// ============ BLOG JURÍDICO (público) ============
//
// Alimentado por um robô de conteúdo EXTERNO (projeto Claude Code autônomo, fora
// deste repositório) que pesquisa jurisprudência/legislação/doutrina e envia
// rascunhos via POST /api/blog/draft (autenticado por BLOG_ROBOT_SECRET). Todo
// rascunho nasce como AGUARDANDO_REVISAO — só é publicado quando um usuário
// humano logado confirma em Configurações → Blog Jurídico → Revisão Pendente.

model BlogPost {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  area           String    // ex: Civil, Consumerista, Empresarial, Tributário, Trabalhista, Previdenciário, Administrativo, Licitação, Compliance, Due Diligence, Contratual, Responsabilidade Civil, Execuções
  type           String    @default("NOTICIA") // NOTICIA | ANALISE
  summary        String
  content        String    // corpo da matéria, pode ser markdown simples
  sources        String?   // URLs das fontes usadas, uma por linha (texto simples)
  imageUrl       String?   // preenchido manualmente pelo admin antes de publicar
  status         String    @default("AGUARDANDO_REVISAO") // AGUARDANDO_REVISAO | PUBLICADO | REJEITADO
  rejectedReason String?
  reviewedById   String?
  reviewedBy     User?     @relation("BlogPostReviewer", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([area])
}

// ============ BIBLIOTECA DE FOTOS ============
//
// Fotos enviadas por um admin (upload real, armazenado no Vercel Blob — ver
// @vercel/blob e BLOB_READ_WRITE_TOKEN). Usadas tanto para ilustrar matérias do
// blog jurídico (sugestão automática por área) quanto como camada de fundo
// decorativa, de baixa opacidade, atrás do conteúdo do sistema.

model Photo {
  id        String   @id @default(cuid())
  url       String   // URL pública do Vercel Blob
  category  String   // mesma taxonomia livre de BlogPost.area, + "Todos" para fotos só decorativas/ambiente (curinga)
  court     String   @default("TODOS") // tribunal retratado na foto: STF, STJ, TRT/TST, TJ, TRF, TODOS (curinga)
  caption   String?  // legenda opcional, ex: para crédito/descrição da imagem
  createdAt DateTime @default(now())

  @@index([category])
}

// ============ TABELAS DO ROBÔ PYTHON (robo-publicacoes/, Railway) ============
//
// Estes 4 modelos NÃO são usados pelo código TypeScript — eles existem só para
// que o Prisma "enxergue" as tabelas que o robô Python (SQLAlchemy) cria no
// MESMO banco Postgres. Sem isso, `prisma db push` trata essas tabelas como
// "órfãs" (não descritas no schema) e as APAGA na próxima migração — foi
// exatamente isso que aconteceu em 2026-07-20. Os tipos/nomes de coluna abaixo
// espelham robo-publicacoes/src/db.py; se o robô mudar a estrutura lá, replicar
// a mudança aqui também.

model RoboPublicacao {
  idComunicacao        String    @id @map("id_comunicacao")
  oab                  String
  uf                   String
  nomeAdvogado         String?   @map("nome_advogado")
  numeroProcesso       String    @map("numero_processo")
  tribunal             String?
  dataDisponibilizacao String?   @map("data_disponibilizacao")
  tipoComunicacao      String?   @map("tipo_comunicacao")
  teor                 String?
  dataCaptura          DateTime  @default(now()) @map("data_captura")
  statusLido           Boolean   @default(false) @map("status_lido")

  @@map("publicacoes")
}

model RoboAndamento {
  id                 Int      @id @default(autoincrement())
  numeroProcesso     String   @map("numero_processo")
  tribunal           String?
  dataMovimentacao   String   @map("data_movimentacao")
  codigoMovimento    String   @map("codigo_movimento")
  descricaoMovimento String?  @map("descricao_movimento")
  dataCaptura        DateTime @default(now()) @map("data_captura")
  statusLido         Boolean  @default(false) @map("status_lido")

  @@unique([numeroProcesso, dataMovimentacao, codigoMovimento], name: "uq_andamento_processo_data_codigo")
  @@map("andamentos")
}

model RoboProcessoMonitorado {
  numeroProcesso String   @id @map("numero_processo")
  origem         String
  dataInclusao   DateTime @default(now()) @map("data_inclusao")
  oabRelacionada String?  @map("oab_relacionada")

  @@map("processos_monitorados")
}

model RoboExecucaoLog {
  id          Int      @id @default(autoincrement())
  fonte       String
  sucesso     Boolean
  detalhe     String?
  executadoEm DateTime @default(now()) @map("executado_em")

  @@map("execucao_log")
}
